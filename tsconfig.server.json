{
  "compilerOptions": {
    /* Referenced by `tsconfig.json`, so `tsc -b` typechecks `server/`.
       Typecheck only: the backend runs TypeScript directly under Bun
       (`CMD ["bun", "server/index.ts"]`), so there is no compile step and
       emitting into `server/dist` would just produce dead artifacts on every
       `bun run build`. Buildinfo goes to `node_modules/.tmp` like the other
       projects — `prebuild` already clears that directory. */
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.server.tsbuildinfo",
    "noEmit": true,
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "server",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/dist"]
}
