{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server/dist",
    "rootDir": "server",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmitOnError": false,
    "declaration": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["server/dist", "server/seed.ts"]
}
