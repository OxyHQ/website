# Static asset folders — return a real 404 instead of falling back to
# index.html when the file doesn't exist. Prevents the browser
# "MIME type text/html" error when a cached index.html references a
# stale hashed bundle after a deploy.
/assets/*  /404  404
/images/*  /404  404
/fonts/*   /404  404
/models/*  /404  404

# SPA fallback — every other path renders the React shell.
/*  /index.html  200
