# FedCM IdP well-known. Chrome fetches this from the eTLD+1 (oxy.so) to
# validate the IdP config at https://auth.oxy.so/fedcm.json. It MUST be
# served as application/json, otherwise FedCM rejects the IdP and
# navigator.credentials.get() throws NetworkError before any UI shows —
# breaking login on accounts.oxy.so and every Oxy app.
/.well-known/web-identity
  Content-Type: application/json
  Cache-Control: public, max-age=300, must-revalidate

# Static assets are content-hashed, but they must NOT be cached `immutable`.
# The SPA catch-all (`/*  /index.html  200`) serves index.html (200, HTML) for
# any asset URL that briefly 404s during a deploy's edge propagation, and an
# `immutable, max-age=31536000` header then freezes that HTML under a `.js` URL
# for a year — a poisoned entry that blanks the whole app and cannot be purged
# without dashboard access. `no-cache` still stores the file but revalidates it
# against origin on every use, so a poisoned entry self-heals on the next
# request instead of persisting. Revalidation of an unchanged hashed file is a
# cheap 304.
/assets/*
  Cache-Control: public, no-cache

# Cache images
/images/*
  Cache-Control: public, max-age=2592000

# Cache fonts
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — always revalidate so browsers pick up new asset hashes after deploys
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Security headers
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
