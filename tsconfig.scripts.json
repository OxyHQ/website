{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.scripts.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    /* Build scripts run under Bun (`import.meta.dir`); the Cloudflare Pages
       function under workerd (`PagesFunction`, `HTMLRewriter`). */
    "types": ["bun", "@cloudflare/workers-types"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "resolveJsonModule": true,
    /* `prerender.ts` imports types from `src/entry-server.tsx`; parsing a
       `.tsx` file requires a jsx mode even though scripts emit no JSX. */
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["scripts", "functions"]
}
